# Copy this file to .env and fill in your real values.
# In Railway, set these as Variables on the luumil-backend service instead of using a file.

# Provided automatically by Railway when you link the PostgreSQL service
DATABASE_URL=postgresql://user:password@host:port/database

# Port Railway will inject automatically — you usually don't need to set this yourself
PORT=3001

# Shared access code that both users will type in to log in
ACCESS_CODE=luumil2024

# Secret used to sign login tokens — make this a long random string in production
JWT_SECRET=change-this-to-a-long-random-string

NODE_ENV=production
